# 项目数据下载鉴权配置（示例）
# 不要在仓库提交真实值。请复制为 config/env/backend.env 后填写真实配置。
ASC_PROJECT_DATA_DOWNLOAD_PASSWORD_SHA256=your_password_sha256
ASC_PROJECT_DATA_DOWNLOAD_JWT_SECRET=your_random_jwt_secret

# 兼容旧变量名（不推荐新环境继续使用）
# ASC_DATA_DOWNLOAD_PASSWORD_SHA256=your_password_sha256
# ASC_DATA_DOWNLOAD_JWT_SECRET=your_random_jwt_secret
