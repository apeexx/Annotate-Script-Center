# 项目数据下载鉴权配置请放到 config/env/backend.env（不要写在 ai.env）
# config/env/ai.env 与 config/env/ai.local.env 为本地/服务器真实文件，默认不提交。
# 代码默认值优先；只有在你需要偏离默认行为时，才补写覆盖项。

# DashScope（当前唯一维护中的 AI provider）
DASHSCOPE_API_KEY=your_dashscope_api_key

# 可选：仅在需要替换兼容层地址时覆盖。
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：共享 AI job 配置。推荐写 ASC_AI_JOB_*；未写时回退代码默认值。
# ASC_AI_JOB_TIMEOUT_MS=60000
# ASC_AI_JOB_TTL_MS=1800000
# ASC_AI_JOB_MAX_SIZE=600
# ASC_AI_JOB_POLL_INTERVAL_MS=1000
